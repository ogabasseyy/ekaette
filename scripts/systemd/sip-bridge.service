[Unit]
Description=Ekaette SIP Bridge (Africa's Talking)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=mac
WorkingDirectory=/home/mac
Environment=PYTHONPATH=/home/mac
EnvironmentFile=/home/mac/sip_bridge.env
ExecStart=/home/mac/sip_venv/bin/python -m sip_bridge.main
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sip-bridge
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/home/mac

[Install]
WantedBy=multi-user.target
