# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

project_id      = "ekaette"
region          = "us-central1"
app_name        = "ekaette"
# Pin to a specific image tag — never use :latest in production
container_image = "us-central1-docker.pkg.dev/ekaette/ekaette/ekaette:v1.0.0"
min_instances   = 1
max_instances   = 10

env_vars = {
  LIVE_MODEL_ID       = "gemini-live-2.5-flash-native-audio"
  LIVE_MODEL_FALLBACK = "gemini-live-2.5-flash-native-audio"
  VISION_MODEL        = "gemini-3-flash-preview"
  # WARNING: Use specific origins in production (e.g. "https://ekaette.vercel.app")
  ALLOWED_ORIGINS     = "*"
}

# ── WhatsApp Cloud API (HTTPS LB + Cloud Tasks) ──
wa_webhook_domain     = "wa-webhook.ekaette.com"
wa_service_api_domain = "wa-service.ekaette.com"
app_public_domain     = "app.ekaette.com"
wa_vm_egress_cidrs    = ["<VM_NAT_CIDR>/32"]

wa_cloud_tasks_queue_name  = "wa-webhook-processing"
wa_cloud_tasks_max_attempts = 3
wa_replay_bucket_name      = "ekaette-wa-replay"
wa_replay_blob_prefix      = "wa/replay/"
wa_replay_blob_ttl_days    = 1
