# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

project_id      = "ekaette"
region          = "us-central1"
app_name        = "ekaette"
# Pin to a specific image tag — never use :latest in production
container_image = "us-central1-docker.pkg.dev/ekaette/ekaette/ekaette:v1.0.0"
min_instances   = 1
max_instances   = 10

env_vars = {
  LIVE_MODEL_ID       = "gemini-2.5-flash-native-audio-preview-12-2025"
  LIVE_MODEL_FALLBACK = "gemini-2.5-flash-preview-native-audio-dialog"
  VISION_MODEL        = "gemini-3-flash-preview"
  # WARNING: Use specific origins in production (e.g. "https://ekaette.vercel.app")
  ALLOWED_ORIGINS     = "*"
}
