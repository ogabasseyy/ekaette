# ═══════════════════════════════════════════
# Ekaette Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Development Mode (Gemini Live API via AI Studio) ──
# Set to FALSE for development (free API key)
# Set to TRUE for production (Vertex AI on Cloud Run)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── API Key (development only, not needed when VERTEXAI=TRUE) ──
GOOGLE_API_KEY=

# ── Google Cloud (always needed for Firestore/Storage/Search) ──
GOOGLE_CLOUD_PROJECT=ekaette
GOOGLE_CLOUD_LOCATION=us-central1

# ── Models ──
# Voice model (Live API — only 2.5 has native audio)
LIVE_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025
# Fallback voice model (if primary is retired)
LIVE_MODEL_FALLBACK=gemini-2.5-flash-preview-native-audio-dialog
# Vision/reasoning model (Standard API)
VISION_MODEL=gemini-3-flash-preview
# Optional: client-driven speech activity (manual VAD) for faster barge-in.
# FALSE = Gemini automatic activity detection (recommended default)
# TRUE  = frontend sends activity_start/activity_end signals
MANUAL_VAD=FALSE

# ── Application ──
APP_NAME=ekaette
PORT=8000
LOG_LEVEL=INFO

# ── Registry Cutover (Phase 7) ──
# TRUE (default): registry-backed templates/companies are authoritative
# FALSE: legacy compat loaders/onboarding fallback paths
REGISTRY_ENABLED=TRUE
# TRUE: reject company/template mismatches from client inputs
REGISTRY_REQUIRE_COMPANY_TEMPLATE_MATCH=FALSE

# ── Session Storage (S6) ──
# database (recommended): ADK DatabaseSessionService via SQL URL
# memory: in-process only (no persistence)
# vertex: managed Vertex AI sessions (requires Agent Engine setup)
SESSION_BACKEND=database
SESSION_DB_URL=sqlite+aiosqlite:///./.data/ekaette_sessions.db
# Used only when SQL backend dependencies are unavailable.
SESSION_FILE_PATH=./.data/ekaette_sessions_snapshot.json

# ── Memory Bank (Agent Engine) ──
# Created via Agent Engine setup — leave blank until created
AGENT_ENGINE_ID=
# Memory backend: auto (recommended), vertex (strict), memory (local only)
# auto: if AGENT_ENGINE_ID is set, Vertex Memory Bank is used automatically.
MEMORY_BACKEND=auto

# ── Cloud Storage ──
MEDIA_BUCKET=

# ── Security ──
# Comma-separated allowed origins for CORS/WS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
TOKEN_ALLOWED_TENANTS=public
TOKEN_TTL_SECONDS=300
TOKEN_NEW_SESSION_TTL_SECONDS=600
TOKEN_MAX_USES=1
TOKEN_RATE_LIMIT=10
UPLOAD_RATE_LIMIT=20
RATE_LIMIT_WINDOW=60
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
MAX_UPLOAD_BYTES=10485760

# ── Compaction ──
COMPACTION_ENABLED=true
COMPACTION_MODEL=gemini-3-flash-preview
COMPACTION_INTERVAL=5
COMPACTION_OVERLAP_SIZE=1
# Optional: token-based compaction (must set both)
# COMPACTION_TOKEN_THRESHOLD=50000
# COMPACTION_EVENT_RETENTION_SIZE=10

# ── Production Hardening ──
# Admin auth mode: headers (local/dev), iap (Cloud Run + IAP), hybrid (both)
ADMIN_AUTH_MODE=headers
# IAP audience (required when ADMIN_AUTH_MODE=iap or hybrid)
ADMIN_IAP_AUDIENCE=
# Idempotency store backend: memory (default) or firestore (distributed)
IDEMPOTENCY_STORE_BACKEND=memory
# Connector circuit breaker backend: memory (default) or firestore (distributed)
CONNECTOR_CIRCUIT_BACKEND=memory
# Connector write lock backend: memory (default) or firestore (distributed)
CONNECTOR_LOCK_BACKEND=memory

# ── Africa's Talking ──
AT_USERNAME=sandbox
AT_API_KEY=
AT_ENVIRONMENT=sandbox
AT_VIRTUAL_NUMBER=+23417006000
AT_WEBHOOK_SHARED_SECRET=
AT_ALLOWED_SOURCE_IPS=
AT_VOICE_ENABLED=false
AT_SMS_ENABLED=false
AT_CALLBACK_DIAL_FALLBACK_ENABLED=true
AT_RECORDING_ENABLED=false
AT_RECORDING_DISCLOSURE=This call may be recorded for quality assurance.
AT_CALL_METADATA_RETENTION_DAYS=90
AT_SMS_RETENTION_DAYS=30

# ── SIP Bridge (separate process) ──
SIP_BRIDGE_HOST=0.0.0.0
SIP_BRIDGE_PORT=6060
SIP_PUBLIC_IP=
SIP_BRIDGE_ENDPOINT=
SIP_ALLOWED_PEERS=
SIP_SYSTEM_INSTRUCTION=
SIP_GEMINI_VOICE=Aoede
SIP_COMPANY_ID=ekaette-electronics
SIP_TENANT_ID=public
SIP_HEALTH_PORT=8081
